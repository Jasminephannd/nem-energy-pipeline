{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-nem-v3gnwzv72hd7s"
		},
		"ls_adls_nem_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stnemv3gnwzv72hd7s.dfs.core.windows.net/"
		},
		"ls_sql_nem_gold_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-nem-v3gnwzv72hd7s.database.windows.net"
		},
		"ls_sql_nem_gold_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-nem-gold"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-nem-v3gnwzv72hd7s_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_nem_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_nem_properties_typeProperties_url')]"
					},
					"ls_sql_nem_gold_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_nem_gold_properties_typeProperties_server')]"
					},
					"ls_sql_nem_gold_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_nem_gold_properties_typeProperties_database')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}